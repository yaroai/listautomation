# generated / user content — not part of the project
output/
uploads/
assets/

# source footage dropped in the project root. These are GBs each and blow past
# GitHub's 100 MB per-file limit — they are never part of the repo.
*.mov
*.MOV
*.mp4
*.MP4
*.m4v

# ...but the split-screen overlay bank has to ship with the app. Without this
# the rules above would swallow it, and split screen would work locally and
# find an empty bank/ in production.
!bank/**

# python
__pycache__/
*.pyc
